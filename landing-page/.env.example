# Base URL of the backend. When set, landing-page fetches trips and instant queue from the backend and creates bookings there (same backend as mobile and admin-web).
# Example: http://localhost:3000
# VITE_API_BASE_URL=http://localhost:3000

# Stripe publishable key for card payments on the landing page (required when using card payment).
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: passenger user id used when creating a booking from the landing page (default: u_passenger_1)
# VITE_BOOKING_PASSENGER_ID=u_passenger_1
