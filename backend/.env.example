# Database
# Option A (recommended): Create a dedicated user and database. In psql as postgres run:
#   CREATE USER "user" WITH PASSWORD 'password';
#   CREATE DATABASE ihute_2 OWNER "user";
#   \q
# Option B: Use the postgres superuser — set its password in pgAdmin or: psql -U postgres -c "ALTER USER postgres PASSWORD 'yourpassword';"
# Then use: postgresql://postgres:yourpassword@localhost:5432/ihute_2
DATABASE_URL="postgresql://user:password@localhost:5432/ihute_2"

# Auth
JWT_SECRET="your-jwt-secret-change-in-production"

# Stripe (payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Ticket delivery (email)
RESEND_API_KEY="re_..."
RESEND_FROM="Ihute <noreply@yourdomain.com>"

# PawaPay (mobile money / deposit + payout)
PAWAPAY_API_KEY=""
PAWAPAY_WEBHOOK_SECRET=""
PAWAPAY_REDIRECT_BASE=""

# Server
PORT=3000
# Comma-separated origins for admin-web, landing-page, and mobile. Examples:
# - Admin (Vite): http://localhost:5173
# - Landing (Vite): http://localhost:5174
# - Expo web/simulator: http://localhost:8081
# - Physical device: use your PC IP, e.g. http://192.168.1.105:3000 (device must call backend by IP)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:8081"
