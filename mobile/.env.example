# Base URL of the backend (required). Same URL as landing and admin. The app uses only the real backend (no mocks).
# - iOS Simulator / web: http://localhost:3000
# - Android emulator: http://10.0.2.2:3000
# - Physical device (same Wi-Fi as your PC): http://YOUR_PC_IP:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# WhatsApp number for dispute/support (digits only, e.g. 250788123456). User is taken to this number when they tap "Dispute via WhatsApp".
# EXPO_PUBLIC_DISPUTE_WHATSAPP_NUMBER=250788123456
