# API server URL — app must reach the machine where "npm run dev" runs.
# Get your PC IP: run "ipconfig" and use IPv4 Address (e.g. 192.168.1.105).
# - Android Emulator: leave as localhost (app uses 10.0.2.2 automatically)
# - iOS Simulator or physical device: use your PC IP, e.g. http://192.168.1.105:3000
# Then restart Expo (npm start in this folder).
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.66:3000
